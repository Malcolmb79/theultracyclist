# Required by api/strava-activities.ts. Set the real values in Vercel
# (Project Settings -> Environment Variables) and, for local `vercel dev`,
# in a git-ignored .env.local — never commit actual secrets here.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# Required by api/whoop-data.ts.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=

# Used by api/whoop-data.ts and api/health-data.ts to self-persist rotated
# tokens / pushed data back into this Vercel project's env vars.
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# Required by api/health-data.ts. APPLE_HEALTH_WEBHOOK_SECRET authenticates
# POSTs from an iOS Shortcut; APPLE_HEALTH_HISTORY starts as "[]" and is
# updated in place by the webhook.
APPLE_HEALTH_WEBHOOK_SECRET=
APPLE_HEALTH_HISTORY=[]

# Optional: a Vercel Deploy Hook URL (Project Settings -> Git -> Deploy Hooks).
# When set, api/health-data.ts triggers a redeploy after each webhook POST so
# the pushed data shows up without waiting for the next code change.
HEALTH_DATA_DEPLOY_HOOK_URL=
